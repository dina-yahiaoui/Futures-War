# Configuration de l'API Futures War
# Copier ce fichier en .env et modifier les valeurs

# Token d'authentification pour l'API
API_BEARER_TOKEN=futures-war-secret-token-2026

# Configuration Whisper
WHISPER_MODEL_SIZE=base

# Configuration Z-Image / ComfyUI
COMFY_UI_URL=http://localhost:8188
ZIMAGE_MODEL=Tongyi-MAI/Z-Image-Turbo

# Configuration Ollama (optionnel)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b